# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Auth
AUTH_SECRET="generate-with-npx-auth-secret"
AUTH_URL="http://localhost:3000"

# Threat Intelligence APIs
VIRUSTOTAL_API_KEY="your_virustotal_api_key"

# OpenRouter (OpenAI-compatible API — get key at https://openrouter.ai/keys)
OPENAI_API_KEY="your_openrouter_api_key"
OPENAI_MODEL="openai/gpt-oss-120b:free"
OPENROUTER_FALLBACK_MODEL="openai/gpt-oss-20b:free"
